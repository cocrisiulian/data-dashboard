# Copy this file to .env.local and fill with your Supabase project values

# Supabase (client-side)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only key for server actions that need to bypass RLS (never expose to browser)
# Preferred variable name
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Alternative names also supported by codebase (optional)
# SUPABASE_SERVICE_ROLE=
# SUPABASE_SERVICE_KEY=

# Which schema to use for lab exercises (default: labs)
LABS_SCHEMA=labs