/**
 * LABORATORUL 5 - MVC CRUD
 * MODEL: Plan (Prisma Schema)
 */

// prisma/schema.prisma
model Plan {
  id              String   @id @default(uuid())
  name            String   @unique
  maxFiles        Int      @map("max_files")
  maxCharts       Int      @map("max_charts")
  maxDashboards   Int      @map("max_dashboards")
  price           Decimal  @default(0) @db.Decimal(10, 2)
  createdAt       DateTime @default(now()) @map("created_at")

  users           User[]

  @@map("plans")
}

/**
 * EXPLICAȚIE MODEL:
 * 
 * 1. Fields:
 *    - id: UUID generat automat (primary key)
 *    - name: String unique (Free, Premium, Enterprise)
 *    - maxFiles: Integer - limita fișiere per plan
 *    - maxCharts: Integer - limita grafice per plan
 *    - maxDashboards: Integer - limita dashboard-uri per plan
 *    - price: Decimal(10,2) - preț lunar ($9.99)
 *    - createdAt: Timestamp - data creare
 * 
 * 2. Relations:
 *    - users User[] - One-to-Many cu User
 *    - Un plan poate avea mulți utilizatori
 * 
 * 3. Mapping:
 *    - camelCase în Prisma → snake_case în PostgreSQL
 *    - maxFiles → max_files
 *    - @@map("plans") - tabelul se numește "plans"
 * 
 * 4. Database Table SQL:
 *    CREATE TABLE "plans" (
 *      "id" TEXT NOT NULL,
 *      "name" TEXT NOT NULL,
 *      "max_files" INTEGER NOT NULL,
 *      "max_charts" INTEGER NOT NULL,
 *      "max_dashboards" INTEGER NOT NULL,
 *      "price" DECIMAL(10,2) NOT NULL DEFAULT 0,
 *      "created_at" TIMESTAMP(3) NOT NULL DEFAULT CURRENT_TIMESTAMP,
 *      CONSTRAINT "plans_pkey" PRIMARY KEY ("id"),
 *      CONSTRAINT "plans_name_key" UNIQUE ("name")
 *    );
 */
